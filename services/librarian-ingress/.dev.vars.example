# Copy to .dev.vars for `wrangler dev`. NEVER commit real values.
# In production these are set via `wrangler secret put <NAME>`.

# Bearer token the phone connector presents to this Worker. Long random string.
CONNECTOR_TOKEN=replace-with-a-long-random-string

# Fine-grained GitHub PAT: repository access limited to agent-mesh-bus ONLY,
# permission Contents: Read and write. No other scopes.
GITHUB_TOKEN=github_pat_xxx

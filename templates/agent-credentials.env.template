# ~/.agent-credentials.env   (mode 600)  -- NEVER commit
# Key names are published to the repo during registration.
# Values never leave this file: not into messages, status, logs, or transcripts.
GH_PAT_RESEARCH=
OLCF_PROJECT_ID=
# Email ingress -- only on the node holding the email-monitor role
# (see product/spec/librarian-email-ingress.md). Names published; values never
# leave this file. The shared secret is stripped from mail before any bus write.
GMAIL_LIBRARIAN_OAUTH=        # Gmail read/label/mark-read token (gmail.modify scope)
LIBRARIAN_EMAIL_SECRET=       # shared key senders put on the X-Mesh-Key body line

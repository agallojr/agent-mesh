# ~/.agent-identity.env   (mode 644)  -- NEVER commit
# Generate AGENT_ID once, then treat as immutable:  openssl rand -hex 3
AGENT_ID=CHANGEME
AGENT_NAME=CHANGEME
AGENT_CONTEXT=CHANGEME          # frontier-login | wsl-laptop | linux-server | macos-laptop
POLL_INTERVAL_SEC=300
# AGENT_ROLES: comma-separated roles this node holds. Each role is a queue the
# node monitors and claims work from (tasks/roles/<role>/), and is how senders
# address this kind of work. A node may hold many roles; a role may be held by
# many nodes. Roles that write per-task output (build, install, slurm.submit)
# scale to any number of holders. Shared-output roles (librarian, archiver) write
# a shared namespace and should be held by exactly one node -- this is an operating
# convention, not enforced by the mesh.
# (Back-compat: a lone legacy AGENT_ROLE is read as a one-role list.)
AGENT_ROLES=build,install,slurm.submit,results.groom
# REPO_PATH MUST be a literal absolute path -- no $HOME, ~, or other expansion.
# It must match a line in ~/.claude/mesh-git-allowlist.txt verbatim, and the
# git gate denies any git command whose -C target is not a literal path.
REPO_PATH=/abs/path/to/agent-mesh
